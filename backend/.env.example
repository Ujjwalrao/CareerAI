# Neon Postgres connection string (get from neon.tech dashboard)
# Must have pgvector extension enabled: CREATE EXTENSION IF NOT EXISTS vector;
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/careerai?sslmode=require

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Groq (free tier: console.groq.com/keys) — used for parsing fallback, rewriting, gap analysis, interview Q&A
GROQ_API_KEY=your-groq-key

# Gemini (free tier: aistudio.google.com/apikey) — used only for embeddings (JD matching)
GEMINI_API_KEY=your-gemini-key

# CORS — your Vercel frontend URL
FRONTEND_ORIGIN=http://localhost:3000

# Telegram bot (free — create via @BotFather, get token instantly)
# Used for application follow-up reminders
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_BOT_USERNAME=YourCareerAIBot

# Shared secret the GitHub Actions reminder-cron workflow must send —
# prevents randoms on the internet from triggering mass Telegram sends
CRON_SECRET=generate-a-random-string-here
