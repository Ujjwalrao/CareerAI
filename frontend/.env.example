# URL of your FastAPI backend (local dev or your Render deployment)
# The old GEMINI_API_KEY/APP_URL vars from AI Studio are no longer used —
# all AI calls now go through the backend, not the browser.
VITE_API_URL=http://localhost:8000

# Same Google OAuth Client ID as the backend's GOOGLE_CLIENT_ID
# (console.cloud.google.com → APIs & Services → Credentials)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
